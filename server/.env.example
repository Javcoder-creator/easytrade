# ===================================
# EasyTrade Server - Environment Variables (shablon)
# Haqiqiy qiymatlarni .env faylida saqlang, .env ni git ga commit qilmang!
# ===================================

# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=easytrade
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# JWT — kalitlar bo‘lishi kerak (token emas!). Kuchli random matn yarating.
JWT_SECRET=your_long_random_jwt_secret_here
JWT_REFRESH_SECRET=your_long_random_refresh_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis (ixtiyoriy)
REDIS_URL=redis://localhost:6379

# CORS — bitta URL yoki vergul bilan ajratilgan ro‘yxat (masalan: http://localhost:3000,https://myapp.com)
CLIENT_URL=http://localhost:3000

# PostgreSQL — Render yoki boshqa hosting bergan DATABASE_URL (production)
# DATABASE_URL=postgresql://user:password@host:5432/database_name
